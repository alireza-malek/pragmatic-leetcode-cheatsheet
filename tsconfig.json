{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true
  },
  "include": [".vitepress/**/*.ts", ".vitepress/**/*.vue", "scripts/**/*.ts"]
}
